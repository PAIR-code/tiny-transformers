{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "tiny-transformers": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "changeDetection": "OnPush"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "dist/tiny-transformers"
            },
            "index": "src/index.html",
            "polyfills": [],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets",
              {
                "glob": "**/*",
                "input": "src/assets/",
                "output": "assets/"
              },
              {
                "glob": "**/*",
                "input": "node_modules/monaco-editor/min/vs",
                "output": "assets/monaco/vs"
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "scripts": [],
            "webWorkerTsConfig": "tsconfig.worker.json",
            "browser": "src/main.ts",
            "allowedCommonJsDependencies": [
              // Used by src/app/berkovich-vis/berkovich-vis.component.ts for rendering LaTeX equations.
              "katex/dist/contrib/auto-render.js",
              // Used by src/lib/data-resolver/data-resolver.ts for JSON5 parsing.
              "json5",
              // Used by @tensorflow/tfjs-data dataset package.
              "seedrandom",
              // Transitively referenced by @tensorflow/tfjs-core node platform implementation.
              "node-fetch",
              // Transitively referenced by @tensorflow/tfjs-data utility helpers.
              "string_decoder",
              // Transitively referenced by @tensorflow/tfjs-core hash utilities.
              "long"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "25kb",
                  "maximumError": "30kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "tiny-transformers:build:production"
            },
            "development": {
              "buildTarget": "tiny-transformers:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "proxyConfig": "./proxy.conf.json",
            "verbose": true
          }
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "tiny-transformers:build"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "tsconfig.spec.json",
            "browsers": ["chromium"],
            "headless": true,
            "browserViewport": "1280x768"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "442ae86d-f19a-4f71-8911-11a889937e6b"
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}