{
  "name": "animated-transformers",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "concurrently 'ng serve' 'ts-node src/weblab-examples/build.script.ts --mode=serve'",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "build-test-workers": "esbuild src/lib/distr-signals/example.worker.ts --bundle --outfile=src/assets/test_only_assets/example.worker.js --format=esm && esbuild src/weblab-examples/tiny-transformer-example/task-cell.worker.ts --bundle --outfile=src/assets/test_only_assets/task-cell.worker.js --format=esm && esbuild src/weblab-examples/tiny-transformer-example/trainer-cell.worker.ts --bundle --outfile=src/assets/test_only_assets/trainer-cell.worker.js --format=esm",
    "pretest": "pnpm build-test-workers",
    "test": "ng test --watch"
  },
  "node": ">=22.7.0",
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@material-design-icons/svg": "^0.14.13",
    "@tensorflow/tfjs": "^4.20.0",
    "@tensorflow/tfjs-layers": "^4.22.0",
    "@tensorflow/tfjs-vis": "^1.5.1",
    "@trpc/client": "^11.0.0-rc.730",
    "@trpc/server": "^11.0.0-rc.730",
    "buffer": "^6.0.3",
    "d3": "^7.8.0",
    "d3-color": "^3.1.0",
    "d3-selection": "^3.0.0",
    "glob": "^11.0.1",
    "gpt-tokenizer": "2.8.1",
    "json5": "^2.2.3",
    "mini-parse": "^0.6.9",
    "monaco-editor": "^0.55.1",
    "msgpackr": "^1.11.0",
    "ngx-markdown": "^20.1.0",
    "rxjs": "~7.5.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.3.0",
    "underscore": "^1.13.6",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@tensorflow/tfjs-node": "^4.20.0",
    "@tsconfig/node18": "^18.2.1",
    "@types/d3": "^7.4.0",
    "@types/jasmine": "~4.3.0",
    "@types/underscore": "^1.11.4",
    "@types/wicg-file-system-access": "^2023.10.5",
    "@types/yargs": "^17.0.24",
    "@vitest/browser-playwright": "^4.1.7",
    "concurrently": "^9.1.2",
    "esbuild": "0.24.2",
    "jasmine-core": "~4.5.0",
    "jsdom": "^29.1.1",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "prettier": "3.4.2",
    "typescript": "^6.0.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.7",
    "zone.js": "~0.15.1"
  }
